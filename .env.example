# === WORKTRACKER AI AGENT — Environment Variables ===
# Salin file ini ke .env dan isi nilai yang sesuai

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id_here

# --- DeepSeek API ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# --- Gemini API (fallback, optional) ---
# GEMINI_API_KEY=your_gemini_api_key_here

# --- Database ---
# SQLite (default untuk development):
DATABASE_URL=sqlite+aiosqlite:///data/worktracker.db
# PostgreSQL (untuk production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/worktracker

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- Gmail Integration (optional) ---
# GMAIL_CREDENTIALS_FILE=./config/gmail_credentials.json

# --- Device Auth ---
# DEVICE_TOKEN=your_device_token_here

# --- Timezone ---
TZ=Asia/Jakarta

# --- Admin IDs (comma-separated) ---
# ADMIN_IDS=123456789,987654321
